# ================================
# Aura Study Planner — .gitignore
# ================================

# === Dependências ===
node_modules/

# === Builds e dist ===
dist/
build/

# === Variáveis de ambiente ===
.env
.env.local
.env.*.local

# === Banco de dados (SQLite dev) ===
*.db
*.db-journal
prisma/dev.db
prisma/dev.db-journal

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Editors / IDEs ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS files ===
.DS_Store
Thumbs.db

# === Agents e IA ===
.agents/
.gemini/
_agents/
_agent/
.agent/

# === Documentação interna (.md explicativos por arquivo) ===
# Os arquivos *.ts.md e *.tsx.md são docs internas de aprendizado.
# O README.md raiz é o único .md commitado no repo.
**/*.ts.md
**/*.tsx.md
**/*.prisma.md
docs/

# === Coverage / Testes ===
coverage/
.nyc_output/

# === Temp ===
tmp/
.tmp/

# === Prisma gerados ===
backend/src/generated/
